# Copia este archivo como .env para probar localhost contra Supabase.
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY
SUPABASE_TICKET_BUCKET=ticket-images
PORT=3030

# TicketAuto / alta asistida con IA para tickets de compra
# Recomendado en Vercel: GEMINI_API_KEY=<tu clave de Gemini>
# Usa llamada REST nativa a Gemini, sin dependencias nuevas. También se aceptan GOOGLE_API_KEY, CONTROLEVENT_GEMINI_API_KEY, GOOGLE_GENERATIVE_AI_API_KEY
# y, por compatibilidad con la variable ya creada, OPENIA_API_KEY.
# Si solo existe OPENAI_API_KEY y NO empieza por sk-, se interpreta como clave Gemini.
# CONTROLEVENT_TICKET_AI_PROVIDER=gemini
# Modelos Gemini: si no indicas uno, se prueban en cascada:
# gemini-2.5-flash, gemini-2.5-flash-lite, gemini-flash-latest, gemini-2.0-flash, gemini-2.0-flash-lite
# GEMINI_MODEL=gemini-2.5-flash

# v19 · Decisión de modelos por funcionalidad
# Zuzu preguntas libres: planificador barato con Flash-Lite; redacción final con Flash.
# CONTROLEVENT_ZUZU_PLANNER_MODEL=gemini-2.5-flash-lite
# CONTROLEVENT_ZUZU_NARRATIVE_MODEL=gemini-2.5-flash
# CONTROLEVENT_ZUZU_STRUCTURED_MODEL=gemini-2.5-flash
# Planificación inicial: total usa Flash por razonamiento, parcial puede usar Lite.
# CONTROLEVENT_INITIAL_PLAN_AI_MODEL=gemini-2.5-flash
# Alta asistida de compras/OCR: por defecto Flash para leer mejor fotos; poner 'lite' para modo económico.
# CONTROLEVENT_TICKET_AI_TIER=flash
# CONTROLEVENT_TICKET_AI_TIER=lite
# Conversión aproximada para trazas de coste.
# CONTROLEVENT_USD_EUR=0.92

# Control de coste Zuzu: auto | ahorro | lite | flash | calidad
CONTROLEVENT_ZUZU_COST_MODE=auto
# Redacción final: auto | lite | flash | calidad
CONTROLEVENT_ZUZU_NARRATIVE_TIER=auto
# Cambio USD->EUR usado solo para estimaciones internas
CONTROLEVENT_USD_EUR=0.92

# VOZ3 GRATIS · micrófono y lectura local de Zuzu
# No necesita variables de entorno, claves, Azure ni OpenAI.
# La voz se elige entre las instaladas o expuestas por cada PC, iPhone, iPad o Android.
